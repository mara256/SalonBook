@model SalonBook.Models.Salon
@{ ViewData["Title"] = "Editează salon"; }

<div class="page-body" style="max-width:600px">
    <div class="page-header">
        <h2>Editează — @Model.Nume</h2>
        <p>Actualizează informațiile salonului tău</p>
    </div>

    <form asp-action="EditeazaSalon" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px"></div>

        <div class="form-group">
            <label asp-for="Nume">Denumire salon</label>
            <input asp-for="Nume" placeholder="ex: Glamour Studio" />
            <span asp-validation-for="Nume" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Adresa">Adresă</label>
            <input asp-for="Adresa" placeholder="Stradă, număr, sector, oraș" />
            <span asp-validation-for="Adresa" class="text-danger"></span>
        </div>

       <div class="form-row">
    <div class="form-group">
        <label>Oră deschidere</label>
        <input type="time" name="OraDeschierii" 
               value="@Model.OraDeschierii.ToString(@"hh\:mm")" />
    </div>
    <div class="form-group">
        <label>Oră închidere</label>
        <input type="time" name="OraInchiderii" 
               value="@Model.OraInchiderii.ToString(@"hh\:mm")" />
    </div>
    </div>

        <div class="form-row">
    <div class="form-group">
        <label>Latitudine</label>
        <input type="text" name="Latitudine" 
               value="@Model.Latitudine?.ToString("G", System.Globalization.CultureInfo.InvariantCulture)"
               placeholder="ex: 44.4268" />
    </div>
    <div class="form-group">
        <label>Longitudine</label>
        <input type="text" name="Longitudine"
               value="@Model.Longitudine?.ToString("G", System.Globalization.CultureInfo.InvariantCulture)"
               placeholder="ex: 26.1025" />
    </div>
    </div>
        <div style="font-size:11px;color:#9b9b9b;margin-top:-8px;margin-bottom:12px">
            Găsește coordonatele pe <a href="https://www.latlong.net" target="_blank" style="color:#185FA5">latlong.net</a>
        </div>

        <div class="form-group">
            <label asp-for="Descriere">Descriere</label>
            <textarea asp-for="Descriere" placeholder="Descrie salonul tău, echipa, produsele folosite..."></textarea>
            <span asp-validation-for="Descriere" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Poză salon</label>
            @if (!string.IsNullOrEmpty(Model.PozaUrl))
            {
                <div style="margin-bottom:8px">
                    <img src="@Model.PozaUrl" style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:0.5px solid #e5e5e5" />
                    <div style="font-size:11px;color:#9b9b9b;margin-top:4px">Poza actuală</div>
                </div>
            }
            <input type="file" name="poza" accept="image/*"
                   style="width:100%;padding:8px 12px;border:0.5px solid #ccc;border-radius:8px;font-size:13px;background:#f5f5f4" />
            <span style="font-size:11px;color:#9b9b9b;margin-top:4px;display:block">Lasă gol pentru a păstra poza actuală.</span>
        </div>

        <div style="display:flex;gap:10px;margin-top:20px">
            <button type="submit" class="btn btn-primary" style="flex:1">Salvează modificările</button>
            <a asp-action="Saloane" class="btn" style="flex:1;text-align:center">Anulează</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}