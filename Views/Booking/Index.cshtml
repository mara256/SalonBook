@model SalonBook.Models.Salon
@{ ViewData["Title"] = "Rezervare — " + Model.Nume; }

<div class="page-body">
    <div class="steps-bar">
        <div class="step-item"><div class="step-circle curr">1</div><div class="step-label">Serviciu</div></div>
        <div class="step-line"></div>
        <div class="step-item"><div class="step-circle">2</div><div class="step-label">Dată &amp; oră</div></div>
        <div class="step-line"></div>
        <div class="step-item"><div class="step-circle">3</div><div class="step-label">Confirmare</div></div>
    </div>

    <div style="font-size:14px;font-weight:500;margin-bottom:16px">
        Alege serviciul dorit — <span style="color:#6b6b6b;font-weight:400">@Model.Nume</span>
    </div>

    @foreach (var serviciu in Model.Servicii)
    {
        <a asp-action="SelectData" asp-route-serviciuId="@serviciu.Id"
           style="display:flex;justify-content:space-between;align-items:center;padding:16px;border:0.5px solid #e5e5e5;border-radius:8px;margin-bottom:8px;text-decoration:none;transition:border-color .15s"
           onmouseover="this.style.borderColor='#1a1a1a'" onmouseout="this.style.borderColor='#e5e5e5'">
            <div>
                <div style="font-size:13px;font-weight:500;color:#1a1a1a">@serviciu.Nume</div>
                <div style="font-size:12px;color:#6b6b6b;margin-top:3px">
                    <span class="badge badge-purple">@serviciu.Categorie</span>
                    &nbsp;@serviciu.DurataMinte minute
                </div>
                @if (!string.IsNullOrEmpty(serviciu.Descriere))
                {
                    <div style="font-size:12px;color:#9b9b9b;margin-top:4px">@serviciu.Descriere</div>
                }
            </div>
            <div style="display:flex;align-items:center;gap:16px;flex-shrink:0">
                <span style="font-size:15px;font-weight:500;color:#1a1a1a">@serviciu.Pret lei</span>
                <span style="font-size:12px;color:#6b6b6b">Selectează →</span>
            </div>
        </a>
    }

    <div style="margin-top:16px">
        <a asp-controller="Salon" asp-action="Index" asp-route-id="@Model.Id" class="btn">← Înapoi la salon</a>
    </div>
</div>
