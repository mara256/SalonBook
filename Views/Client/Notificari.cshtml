@model List<SalonBook.Models.Notificare>
@{ ViewData["Title"] = "Notificările mele"; }

<div class="dashboard-layout">
    <div class="dash-sidebar">
        <div class="dash-user">
            <div class="dash-avatar">@User.Identity!.Name?.Substring(0,2).ToUpper()</div>
            <div>
                <div class="dash-name">@User.Identity.Name</div>
                <div class="dash-role">Client</div>
            </div>
        </div>
        <a asp-action="Index" class="dash-nav-item"><div class="dash-dot"></div>Programările mele</a>
        <a asp-action="Notificari" class="dash-nav-item active"><div class="dash-dot" style="background:#7F77DD"></div>Notificări</a>
    </div>

    <div class="dash-content">
        <div class="page-header">
            <h2>Notificările mele</h2>
            <p>@Model.Count(n => !n.EsteCitita) necitite</p>
        </div>

        @if (!Model.Any())
        {
            <p style="color:#9b9b9b;font-size:13px">Nu ai nicio notificare momentan.</p>
        }

        @foreach (var n in Model)
        {
            <div style="display:flex;gap:12px;padding:14px 0;border-bottom:0.5px solid #f0f0f0">
                <div style="width:8px;height:8px;border-radius:50%;background:@(!n.EsteCitita ? "#7F77DD" : "#e5e5e5");margin-top:5px;flex-shrink:0"></div>
                <div style="flex:1">
                    <div style="font-size:13px;font-weight:@(!n.EsteCitita ? "500" : "400");color:#1a1a1a">@n.Mesaj</div>
                    <div style="font-size:11px;color:#9b9b9b;margin-top:4px">@n.DataCreare.ToString("dd MMM yyyy · HH:mm")</div>
                </div>
                @if (!n.EsteCitita)
                {
                    <form asp-action="MarcheazaCitita" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@n.Id" />
                        <button type="submit" style="font-size:11px;color:#185FA5;background:none;border:none;cursor:pointer;padding:0">Marchează citită</button>
                    </form>
                }
            </div>
        }
    </div>
</div>
