@model List<SalonBook.Models.Salon>
@{ ViewData["Title"] = "Acasă"; }

<div class="hero" style="background: linear-gradient(135deg, #ffffff 0%, #d4b8f0 40%, #3C3489 100%); padding: 120px 24px;">
    <h1 style="font-size: 42px; font-weight: 600; color: #1a1a1a; margin-bottom: 14px;">Programează-te la salonul preferat</h1>
    <p style="font-size: 18px; color: #444; margin-bottom: 28px;">Coafor · Manichiură · Tratamente faciale · Masaj</p>
    <form method="get" asp-action="Index">
        <div class="search-row" style="max-width: 560px; margin: 0 auto;">
            <input name="cautare" value="@ViewBag.Cautare" placeholder="Caută salon sau serviciu..." style="padding: 14px 18px; font-size: 15px;"/>
            <button type="submit" style="padding: 14px 24px; font-size: 15px;">Caută</button>
        </div>
    </form>
</div>

<div class="section" style="border-bottom:0.5px solid #e5e5e5">
    <div class="section-title">Categorii</div>
    <div class="cat-row">
        <a href="?" class="cat-pill @(ViewBag.Categorie == null ? "active" : "")">Toate</a>
        @foreach (var cat in new[] { "Coafor", "Frizerie", "Manichiura", "Proceduri estetice", "Masaj", "Machiaj" })
        {
            <a href="?categorie=@cat@(ViewBag.PretMax != null ? "&pretMax=" + ViewBag.PretMax : "")@(ViewBag.Sortare != null ? "&sortare=" + ViewBag.Sortare : "")"
               class="cat-pill @(ViewBag.Categorie == cat ? "active" : "")">@cat</a>
        }
    </div>
</div>

<div class="section" style="border-bottom:0.5px solid #e5e5e5">
    <div class="section-title">@(Model.Count == 0 ? "Niciun salon găsit" : "Saloane disponibile")</div>
    <div class="cards-grid">
        @foreach (var salon in Model)
        {
            <a asp-controller="Salon" asp-action="Index" asp-route-id="@salon.Id" class="salon-card">
                <div class="card-img">
                    @if (!string.IsNullOrEmpty(salon.PozaUrl))
                    {
                        <img src="@salon.PozaUrl" alt="@salon.Nume" />
                    }
                    else
                    {
                        <span>Fără poză</span>
                    }
                </div>
                <div class="card-body">
                    <div class="card-name">@salon.Nume</div>
                    <div class="card-sub">@salon.Adresa</div>
                    @if (salon.Recenzii.Any())
                    {
                        var rating = salon.Recenzii.Average(r => r.Nota);
                        <div class="card-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span style="color:@(i <= Math.Round(rating) ? "#BA7517" : "#e5e5e5")">★</span>
                            }
                            <span style="font-size:11px;color:#6b6b6b;margin-left:4px">@rating.ToString("F1") (@salon.Recenzii.Count)</span>
                        </div>
                    }
                    else
                    {
                        <div style="font-size:11px;color:#9b9b9b;margin-top:3px">Nicio recenzie încă</div>
                    }
                    @{
                        var acumH = DateTime.Now.TimeOfDay;
                        var deschisH = acumH >= salon.OraDeschierii && acumH <= salon.OraInchiderii;
                    }
                    <div style="margin-top:4px">
                        @if (deschisH)
                        {
                            <span class="badge badge-green" style="font-size:10px">Deschis</span>
                        }
                        else
                        {
                            <span class="badge badge-red" style="font-size:10px">Închis</span>
                        }
                    </div>
                    <div style="margin-top:6px;display:flex;gap:4px;flex-wrap:wrap">
                        @foreach (var cat in salon.Servicii.Select(s => s.Categorie).Distinct().Take(2))
                        {
                            <span class="badge badge-purple">@cat</span>
                        }
                    </div>
                </div>
            </a>
        }
    </div>
</div>

<div class="section" style="position:relative;z-index:1">
    <div class="section-title">Harta saloanelor</div>
    <div style="margin-bottom:12px">
        <input id="cautare-harta" type="text" placeholder="Caută salon după nume..."
               style="width:100%;padding:10px 14px;border:0.5px solid #ccc;border-radius:8px;font-size:14px;background:#f5f5f4;color:#1a1a1a"
               oninput="filtreazaHarta(this.value)"/>
    </div>
    <div id="rezultate-harta" style="display:none;flex-direction:column;gap:6px;margin-bottom:10px;position:relative;z-index:2"></div>
    <div id="map" style="height:500px;border-radius:12px;border:0.5px solid #e5e5e5;overflow:hidden;position:relative;z-index:1"></div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script>
    const map = L.map('map').setView([45.9432, 24.9668], 6);
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap', maxZoom: 19, crossOrigin: true
    }).addTo(map);
    setTimeout(() => { map.invalidateSize(); }, 100);

    const pinMov = L.divIcon({
        html: `<div style="width:24px;height:24px;background:#3C3489;border:2px solid #fff;border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 2px 6px rgba(0,0,0,0.3)"></div>`,
        iconSize: [24, 24], iconAnchor: [12, 24], popupAnchor: [0, -24], className: ''
    });

    const saloane = @Html.Raw(Json.Serialize(Model
        .Where(s => s.Latitudine != null && s.Longitudine != null)
        .Select(s => new { s.Nume, s.Adresa, s.Latitudine, s.Longitudine, s.Id })));

    const markers = [];
    saloane.forEach(s => {
        const marker = L.marker([s.latitudine, s.longitudine], { icon: pinMov }).addTo(map);
        marker.bindPopup(`<div style="font-family:sans-serif;min-width:160px"><div style="font-size:13px;font-weight:500;margin-bottom:4px">${s.nume}</div><div style="font-size:11px;color:#6b6b6b;margin-bottom:8px">${s.adresa}</div><a href="/Salon/Index/${s.id}" style="font-size:12px;color:#3C3489;font-weight:500">Vezi salonul →</a></div>`);
        markers.push({ salon: s, marker: marker });
    });

    setTimeout(() => { map.setView([45.9432, 24.9668], 6); }, 200);

    function filtreazaHarta(query) {
        const q = query.toLowerCase().trim();
        const rezultate = document.getElementById('rezultate-harta');
        rezultate.innerHTML = '';
        if (q === '') {
            rezultate.style.display = 'none';
            markers.forEach(m => m.marker.addTo(map));
            map.setView([45.9432, 24.9668], 6);
            return;
        }
        rezultate.style.display = 'flex';
        const gasite = markers.filter(m => m.salon.nume.toLowerCase().includes(q) || m.salon.adresa.toLowerCase().includes(q));
        markers.forEach(m => map.removeLayer(m.marker));
        if (gasite.length === 0) {
            rezultate.innerHTML = '<div style="font-size:13px;color:#9b9b9b;padding:8px">Niciun salon găsit.</div>';
            return;
        }
        gasite.forEach(m => {
            m.marker.addTo(map);
            const card = document.createElement('div');
            card.style = 'display:flex;justify-content:space-between;align-items:center;padding:10px 14px;border:0.5px solid #e5e5e5;border-radius:8px;cursor:pointer;background:#fff';
            card.innerHTML = `<div><div style="font-size:13px;font-weight:500;color:#1a1a1a">${m.salon.nume}</div><div style="font-size:11px;color:#6b6b6b;margin-top:2px">${m.salon.adresa}</div></div><span style="font-size:12px;color:#3C3489">Vezi pe hartă →</span>`;
            card.onclick = () => { map.invalidateSize(); map.setView([m.salon.latitudine, m.salon.longitudine], 15); setTimeout(() => m.marker.openPopup(), 100); };
            rezultate.appendChild(card);
        });
        if (gasite.length === 1) {
            map.invalidateSize();
            map.setView([gasite[0].salon.latitudine, gasite[0].salon.longitudine], 15);
            setTimeout(() => gasite[0].marker.openPopup(), 100);
        } else {
            const group = L.featureGroup(gasite.map(m => m.marker));
            map.fitBounds(group.getBounds().pad(0.3));
        }
    }
    window.addEventListener('scroll', () => map.invalidateSize());
</script>