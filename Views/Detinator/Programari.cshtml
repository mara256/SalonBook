@model List<SalonBook.Models.Programare>
@{ 
    ViewData["Title"] = "Programări salon"; 
    var salon = ViewBag.Salon as SalonBook.Models.Salon;
    var clientiBlocati = ViewBag.ClientiBlocati as List<string> ?? new List<string>();
    var numarNeprezentari = ViewBag.NumarNeprezentari as Dictionary<string, int> ?? new Dictionary<string, int>();
}

<div class="page-body">
    <div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-start">
        <div>
            <h2>Programări — @salon?.Nume</h2>
            <p>@Model.Count programări totale</p>
        </div>
        <a asp-action="Saloane" class="btn">← Înapoi</a>
    </div>

    <!-- Filtre status -->
    <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap">
        <span style="font-size:12px;color:#6b6b6b;align-self:center">Filtrează:</span>
        <span class="badge badge-amber">
            În așteptare (@Model.Count(p => p.Status == SalonBook.Models.StatusProgramare.InAsteptare))
        </span>
        <span class="badge badge-green">
            Acceptate (@Model.Count(p => p.Status == SalonBook.Models.StatusProgramare.Acceptata))
        </span>
        <span class="badge badge-red">
            Respinse (@Model.Count(p => p.Status == SalonBook.Models.StatusProgramare.Respinsa))
        </span>
        <span class="badge" style="background:#EAF3DE;color:#3B6D11">
            Onorate (@Model.Count(p => p.Status == SalonBook.Models.StatusProgramare.Onorata))
        </span>
        <span class="badge" style="background:#F0EEFF;color:#6b5fc7">
            Neprezentări (@Model.Count(p => p.Status == SalonBook.Models.StatusProgramare.Neprezentat))
        </span>
    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Telefon</th>
                    <th>Serviciu</th>
                    <th>Dată / Oră</th>
                    <th>Status</th>
                    <th>Acțiune</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.OrderByDescending(p => p.DataOra))
                {
                    var esteBlocat = clientiBlocati.Contains(p.ClientId);
                    var neprezentariClient = numarNeprezentari.ContainsKey(p.ClientId) ? numarNeprezentari[p.ClientId] : 0;
                    var esteProblematic = neprezentariClient >= 2;
                    <tr style="@(esteBlocat ? "opacity:0.5" : "")">
                        <td>
                            @p.Client?.Prenume @p.Client?.Nume
                            @if (esteBlocat)
                            {
                                <span class="badge badge-red" style="margin-left:6px">Blocat</span>
                            }
                            @if (!esteBlocat && esteProblematic)
                            {
                                <span class="badge" style="background:#FCEBEB;color:#A32D2D;margin-left:6px" title="Acest client a lipsit de @neprezentariClient ori fără să anuleze">
                                    ⚠ @neprezentariClient neprezentări
                                </span>
                            }
                        </td>
                        <td style="color:#6b6b6b">@p.Client?.PhoneNumber</td>
                        <td>@p.Serviciu?.Nume</td>
                        <td>@p.DataOra.ToString("dd MMM yyyy · HH:mm")</td>
                        <td>
                            @switch (p.Status)
                            {
                                case SalonBook.Models.StatusProgramare.InAsteptare:
                                    <span class="badge badge-amber">În așteptare</span>
                                    break;
                                case SalonBook.Models.StatusProgramare.Acceptata:
                                    <span class="badge badge-green">Acceptată</span>
                                    break;
                                case SalonBook.Models.StatusProgramare.Onorata:
                                    <span class="badge" style="background:#EAF3DE;color:#3B6D11">✓ Onorată</span>
                                    break;
                                case SalonBook.Models.StatusProgramare.Respinsa:
                                    <span class="badge badge-red">Respinsă</span>
                                    break;
                                case SalonBook.Models.StatusProgramare.Anulata:
                                    <span class="badge badge-red">Anulată</span>
                                    break;
                                case SalonBook.Models.StatusProgramare.Neprezentat:
                                    <span class="badge" style="background:#F0EEFF;color:#6b5fc7">✕ Neprezentat</span>
                                    break;
                            }
                        </td>
                        <td>
                            <div style="display:flex;gap:4px;flex-wrap:wrap">

                                @if (p.Status == SalonBook.Models.StatusProgramare.InAsteptare)
                                {
                                    <form asp-action="ActualizeazaStatus" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="programareId" value="@p.Id" />
                                        <input type="hidden" name="salonId" value="@salon?.Id" />
                                        <input type="hidden" name="status" value="Acceptata" />
                                        <button type="submit" class="badge badge-green" style="border:none;cursor:pointer;padding:4px 10px">Acceptă</button>
                                    </form>
                                    <form asp-action="ActualizeazaStatus" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="programareId" value="@p.Id" />
                                        <input type="hidden" name="salonId" value="@salon?.Id" />
                                        <input type="hidden" name="status" value="Respinsa" />
                                        <button type="submit" class="badge badge-red" style="border:none;cursor:pointer;padding:4px 10px">Respinge</button>
                                    </form>
                                }

                                @if (p.Status == SalonBook.Models.StatusProgramare.Acceptata)
                                {
                                    <form asp-action="MarcheazaOnorata" method="post" style="display:inline"
                                          onsubmit="return confirm('Marchezi programarea ca onorată?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="programareId" value="@p.Id" />
                                        <input type="hidden" name="salonId" value="@salon?.Id" />
                                        <button type="submit" style="background:#EAF3DE;color:#3B6D11;border:none;cursor:pointer;padding:4px 10px;border-radius:4px;font-size:11px">
                                            ✓ Onorat
                                        </button>
                                    </form>

                                    @if (p.DataOra < DateTime.Now)
                                    {
                                        <form asp-action="MarcheazaNeprezentat" method="post" style="display:inline"
                                              onsubmit="return confirm('Marchezi că acest client NU s-a prezentat la programare?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="programareId" value="@p.Id" />
                                            <input type="hidden" name="salonId" value="@salon?.Id" />
                                            <button type="submit" style="background:#F0EEFF;color:#6b5fc7;border:none;cursor:pointer;padding:4px 10px;border-radius:4px;font-size:11px">
                                                ✕ Nu s-a prezentat
                                            </button>
                                        </form>
                                    }
                                }

                                @if (!esteBlocat)
                                {
                                    <form asp-action="BlocheazaClient" method="post" style="display:inline"
                                          onsubmit="return confirm('Ești sigur că vrei să blochezi acest client?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="clientId" value="@p.ClientId" />
                                        <input type="hidden" name="salonId" value="@salon?.Id" />
                                        <input type="hidden" name="motiv" value="Client absent" />
                                        <button type="submit" class="badge" style="background:@(esteProblematic ? "#FCEBEB" : "#f5f5f4");color:@(esteProblematic ? "#A32D2D" : "#6b6b6b");border:none;cursor:pointer;padding:4px 10px">
                                            Blochează
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="DezblocheazaClient" method="post" style="display:inline"
                                          onsubmit="return confirm('Ești sigur că vrei să deblochezi acest client?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="clientId" value="@p.ClientId" />
                                        <input type="hidden" name="salonId" value="@salon?.Id" />
                                        <button type="submit" class="badge badge-green" style="border:none;cursor:pointer;padding:4px 10px">
                                            Deblochează
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>