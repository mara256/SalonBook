@{ ViewData["Title"] = "Calendar programări"; }

@{
    var salon = ViewBag.Salon as SalonBook.Models.Salon;
}

<div class="dashboard-layout">
    <div class="dash-sidebar">
        <div class="dash-user">
            <div class="dash-avatar" style="background:#E1F5EE;color:#0F6E56">DS</div>
            <div><div class="dash-name">@salon?.Nume</div><div class="dash-role">Deținător</div></div>
        </div>
        <a asp-action="Index" class="dash-nav-item"><div class="dash-dot"></div>Dashboard</a>
        <a asp-action="Saloane" class="dash-nav-item"><div class="dash-dot"></div>Salonul meu</a>
        <a asp-action="Notificari" class="dash-nav-item"><div class="dash-dot"></div>Notificări</a>
        <a asp-action="Statistici" class="dash-nav-item"><div class="dash-dot"></div>Statistici</a>
        <a asp-action="Calendar" asp-route-salonId="@salon?.Id" class="dash-nav-item active">
            <div class="dash-dot" style="background:#1D9E75"></div>Calendar
        </a>
    </div>

    <div class="dash-content">
        <div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-start">
            <div>
                <h2>Calendar programări</h2>
                <p>@salon?.Nume</p>
            </div>
            <div style="display:flex;gap:8px">
                <button onclick="schimbaVizualizare('saptamana')" id="btn-saptamana"
                        class="btn" style="font-size:12px;padding:6px 14px">Săptămână</button>
                <button onclick="schimbaVizualizare('luna')" id="btn-luna"
                        class="btn btn-primary" style="font-size:12px;padding:6px 14px">Lună</button>
            </div>
        </div>

        <!-- Navigare luna/saptamana -->
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
            <button onclick="navigheaza(-1)" class="btn" style="padding:6px 12px;font-size:18px">‹</button>
            <div id="titlu-calendar" style="font-size:15px;font-weight:500;min-width:200px;text-align:center"></div>
            <button onclick="navigheaza(1)" class="btn" style="padding:6px 12px;font-size:18px">›</button>
            <button onclick="azi()" class="btn" style="font-size:12px;padding:6px 12px">Azi</button>
        </div>

        <!-- Legenda statusuri -->
        <div style="display:flex;gap:16px;margin-bottom:16px;flex-wrap:wrap">
            <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:#6b6b6b">
                <div style="width:10px;height:10px;border-radius:2px;background:#FAEEDA"></div> În așteptare
            </div>
            <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:#6b6b6b">
                <div style="width:10px;height:10px;border-radius:2px;background:#E1F5EE"></div> Acceptată
            </div>
            <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:#6b6b6b">
                <div style="width:10px;height:10px;border-radius:2px;background:#FCEBEB"></div> Respinsă/Anulată
            </div>
        </div>

        <!-- Calendar luna -->
        <div id="view-luna" style="border:0.5px solid #e5e5e5;border-radius:12px;overflow:hidden">
            <div style="display:grid;grid-template-columns:repeat(7,1fr);background:#f5f5f4">
                @foreach (var zi in new[] { "Lun", "Mar", "Mie", "Joi", "Vin", "Sâm", "Dum" })
                {
                    <div style="padding:8px;text-align:center;font-size:12px;font-weight:500;color:#6b6b6b;border-right:0.5px solid #e5e5e5">@zi</div>
                }
            </div>
            <div id="grid-luna" style="display:grid;grid-template-columns:repeat(7,1fr)"></div>
        </div>

        <!-- Calendar saptamana -->
        <div id="view-saptamana" style="display:none;border:0.5px solid #e5e5e5;border-radius:12px;overflow:hidden">
            <div id="header-saptamana" style="display:grid;grid-template-columns:60px repeat(7,1fr);background:#f5f5f4"></div>
            <div id="grid-saptamana" style="display:grid;grid-template-columns:60px repeat(7,1fr);max-height:600px;overflow-y:auto"></div>
        </div>

        <!-- Modal detalii programare -->
        <div id="modal-prog" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.3);z-index:1000;align-items:center;justify-content:center">
            <div style="background:#fff;border-radius:16px;padding:24px;max-width:380px;width:90%;position:relative">
                <button onclick="inchideModal()" style="position:absolute;top:12px;right:12px;border:none;background:none;font-size:20px;cursor:pointer;color:#6b6b6b">×</button>
                <div id="modal-continut"></div>
            </div>
        </div>
    </div>
</div>

<script>
    const programari = @Html.Raw(ViewBag.ProgramariJson);
    let dataActuala = new Date();
    let vizualizare = 'luna';

    function culoareStatus(status) {
        if (status === 'Acceptata') return { bg: '#E1F5EE', text: '#0F6E56', border: '#9FE1CB' };
        if (status === 'InAsteptare') return { bg: '#FAEEDA', text: '#633806', border: '#FAC775' };
        return { bg: '#FCEBEB', text: '#A32D2D', border: '#F7C1C1' };
    }

    function schimbaVizualizare(v) {
        vizualizare = v;
        document.getElementById('view-luna').style.display = v === 'luna' ? 'block' : 'none';
        document.getElementById('view-saptamana').style.display = v === 'saptamana' ? 'block' : 'none';
        document.getElementById('btn-luna').className = v === 'luna' ? 'btn btn-primary' : 'btn';
        document.getElementById('btn-saptamana').className = v === 'saptamana' ? 'btn btn-primary' : 'btn';
        randeaza();
    }

    function navigheaza(dir) {
        if (vizualizare === 'luna') dataActuala.setMonth(dataActuala.getMonth() + dir);
        else dataActuala.setDate(dataActuala.getDate() + dir * 7);
        randeaza();
    }

    function azi() {
        dataActuala = new Date();
        randeaza();
    }

    function randeaza() {
        if (vizualizare === 'luna') randeazaLuna();
        else randeazaSaptamana();
    }

    function randeazaLuna() {
        const an = dataActuala.getFullYear();
        const luna = dataActuala.getMonth();
        const luniRo = ['Ianuarie','Februarie','Martie','Aprilie','Mai','Iunie','Iulie','August','Septembrie','Octombrie','Noiembrie','Decembrie'];
        document.getElementById('titlu-calendar').textContent = `${luniRo[luna]} ${an}`;

        const primaZi = new Date(an, luna, 1);
        const ultimaZi = new Date(an, luna + 1, 0);
        let startZi = primaZi.getDay() - 1;
        if (startZi < 0) startZi = 6;

        const grid = document.getElementById('grid-luna');
        grid.innerHTML = '';

        for (let i = 0; i < startZi; i++) {
            grid.innerHTML += `<div style="min-height:90px;border-right:0.5px solid #e5e5e5;border-bottom:0.5px solid #e5e5e5;background:#fafaf9"></div>`;
        }

        for (let zi = 1; zi <= ultimaZi.getDate(); zi++) {
            const dataZi = new Date(an, luna, zi);
            const esteAzi = dataZi.toDateString() === new Date().toDateString();
            const progZi = programari.filter(p => {
                const d = new Date(p.dataOra);
                return d.getFullYear() === an && d.getMonth() === luna && d.getDate() === zi;
            });

            let continut = `<div style="font-size:12px;font-weight:${esteAzi ? '600' : '400'};color:${esteAzi ? '#3C3489' : '#1a1a1a'};margin-bottom:4px;${esteAzi ? 'background:#EEEDFE;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;' : ''}">${zi}</div>`;

            progZi.slice(0, 3).forEach(p => {
                const c = culoareStatus(p.status);
                const ora = new Date(p.dataOra).toLocaleTimeString('ro-RO', { hour: '2-digit', minute: '2-digit' });
                continut += `<div onclick="deschideModal(${p.id})" style="font-size:10px;padding:2px 4px;border-radius:4px;background:${c.bg};color:${c.text};border:0.5px solid ${c.border};cursor:pointer;margin-bottom:2px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis">${ora} ${p.serviciu}</div>`;
            });

            if (progZi.length > 3) {
                continut += `<div style="font-size:10px;color:#9b9b9b">+${progZi.length - 3} mai mult</div>`;
            }

            grid.innerHTML += `<div style="min-height:90px;border-right:0.5px solid #e5e5e5;border-bottom:0.5px solid #e5e5e5;padding:6px;${esteAzi ? 'background:#FAFAFF;' : ''}">${continut}</div>`;
        }
    }

    function randeazaSaptamana() {
        const startSapt = new Date(dataActuala);
        const ziua = startSapt.getDay() === 0 ? 6 : startSapt.getDay() - 1;
        startSapt.setDate(startSapt.getDate() - ziua);

        const zileRo = ['Lun', 'Mar', 'Mie', 'Joi', 'Vin', 'Sâm', 'Dum'];
        const endSapt = new Date(startSapt);
        endSapt.setDate(endSapt.getDate() + 6);

        document.getElementById('titlu-calendar').textContent =
            `${startSapt.toLocaleDateString('ro-RO', { day: 'numeric', month: 'short' })} — ${endSapt.toLocaleDateString('ro-RO', { day: 'numeric', month: 'short', year: 'numeric' })}`;

        const header = document.getElementById('header-saptamana');
        header.innerHTML = '<div style="padding:8px;border-right:0.5px solid #e5e5e5"></div>';
        for (let i = 0; i < 7; i++) {
            const d = new Date(startSapt);
            d.setDate(d.getDate() + i);
            const esteAzi = d.toDateString() === new Date().toDateString();
            header.innerHTML += `<div style="padding:8px;text-align:center;font-size:12px;font-weight:500;color:${esteAzi ? '#3C3489' : '#6b6b6b'};border-right:0.5px solid #e5e5e5;background:${esteAzi ? '#EEEDFE' : 'transparent'}">${zileRo[i]}<br><span style="font-size:14px;font-weight:${esteAzi ? '600' : '400'}">${d.getDate()}</span></div>`;
        }

        const grid = document.getElementById('grid-saptamana');
        grid.innerHTML = '';

        for (let ora = 8; ora <= 20; ora++) {
            grid.innerHTML += `<div style="padding:4px 6px;font-size:11px;color:#9b9b9b;border-right:0.5px solid #e5e5e5;border-bottom:0.5px solid #f0f0f0;text-align:right">${ora}:00</div>`;
            for (let zi = 0; zi < 7; zi++) {
                const d = new Date(startSapt);
                d.setDate(d.getDate() + zi);
                const progOra = programari.filter(p => {
                    const dp = new Date(p.dataOra);
                    return dp.toDateString() === d.toDateString() && dp.getHours() === ora;
                });
                let celula = `<div style="min-height:48px;border-right:0.5px solid #e5e5e5;border-bottom:0.5px solid #f0f0f0;padding:2px;position:relative">`;
                progOra.forEach(p => {
                    const c = culoareStatus(p.status);
                    celula += `<div onclick="deschideModal(${p.id})" style="font-size:10px;padding:2px 4px;border-radius:4px;background:${c.bg};color:${c.text};border:0.5px solid ${c.border};cursor:pointer;margin-bottom:2px">${p.serviciu}</div>`;
                });
                celula += '</div>';
                grid.innerHTML += celula;
            }
        }
    }

    function deschideModal(id) {
        const p = programari.find(x => x.id === id);
        if (!p) return;
        const c = culoareStatus(p.status);
        const data = new Date(p.dataOra);
        const statusRo = { 'Acceptata': 'Acceptată', 'InAsteptare': 'În așteptare', 'Respinsa': 'Respinsă', 'Anulata': 'Anulată' };

        document.getElementById('modal-continut').innerHTML = `
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
                <div style="width:40px;height:40px;border-radius:10px;background:${c.bg};display:flex;align-items:center;justify-content:center;font-size:18px">📅</div>
                <div>
                    <div style="font-size:15px;font-weight:500">${p.serviciu}</div>
                    <div style="font-size:12px;color:#6b6b6b">${p.client}</div>
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:8px">
                <div style="display:flex;justify-content:space-between;font-size:13px">
                    <span style="color:#6b6b6b">Data</span>
                    <span style="font-weight:500">${data.toLocaleDateString('ro-RO', { weekday: 'long', day: 'numeric', month: 'long' })}</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:13px">
                    <span style="color:#6b6b6b">Ora</span>
                    <span style="font-weight:500">${data.toLocaleTimeString('ro-RO', { hour: '2-digit', minute: '2-digit' })}</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:13px">
                    <span style="color:#6b6b6b">Durată</span>
                    <span style="font-weight:500">${p.durata} min</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:13px">
                    <span style="color:#6b6b6b">Preț</span>
                    <span style="font-weight:500">${p.pret} lei</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:13px">
                    <span style="color:#6b6b6b">Status</span>
                    <span style="padding:2px 10px;border-radius:20px;background:${c.bg};color:${c.text};font-size:12px">${statusRo[p.status] || p.status}</span>
                </div>
            </div>
        `;
        document.getElementById('modal-prog').style.display = 'flex';
    }

    function inchideModal() {
        document.getElementById('modal-prog').style.display = 'none';
    }

    document.getElementById('modal-prog').addEventListener('click', function(e) {
        if (e.target === this) inchideModal();
    });

    randeaza();
</script>