@{ ViewData["Title"] = "Statistici salon"; }

<div class="page-body">
    <div class="page-header"><h2>Statistici salon</h2></div>

    <div class="stats-grid" style="margin-bottom:24px">
        <div class="stat-card">
            <div class="stat-val">@ViewBag.TotalProgramari</div>
            <div class="stat-lbl">Total programări</div>
        </div>
        <div class="stat-card">
            <div class="stat-val" style="color:#3B6D11">@ViewBag.Acceptate</div>
            <div class="stat-lbl">Acceptate</div>
        </div>
        <div class="stat-card">
            <div class="stat-val" style="color:#633806">@ViewBag.InAsteptare</div>
            <div class="stat-lbl">În așteptare</div>
        </div>
        <div class="stat-card">
            <div class="stat-val">@ViewBag.TotalClienti</div>
            <div class="stat-lbl">Clienți unici</div>
        </div>
    </div>

    <div style="margin-bottom:24px">
        <div style="font-size:13px;font-weight:500;margin-bottom:12px">Programări pe lună (ultimele 6 luni)</div>
        <div style="border:0.5px solid #e5e5e5;border-radius:12px;padding:20px">
            <canvas id="chartLuni" height="80"></canvas>
        </div>
    </div>

    <div>
        <div style="font-size:13px;font-weight:500;margin-bottom:12px">Top servicii după programări</div>
        <div style="border:0.5px solid #e5e5e5;border-radius:12px;padding:20px">
            <canvas id="chartServicii" height="80"></canvas>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
    const programariPeLuna = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ProgramariPeLuna));
    const topServicii = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TopServicii));

    new Chart(document.getElementById('chartLuni'), {
        type: 'bar',
        data: {
            labels: programariPeLuna.map(p => p.luna),
            datasets: [{ label: 'Programări', data: programariPeLuna.map(p => p.count),
                backgroundColor: '#E1F5EE', borderColor: '#0F6E56', borderWidth: 1.5, borderRadius: 6 }]
        },
        options: { responsive: true, plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
    });

    new Chart(document.getElementById('chartServicii'), {
        type: 'bar',
        data: {
            labels: topServicii.map(s => s.nume),
            datasets: [{ label: 'Programări', data: topServicii.map(s => s.count),
                backgroundColor: ['#E1F5EE','#EEEDFE','#FAEEDA','#FCEBEB','#E6F1FB'],
                borderColor: ['#0F6E56','#3C3489','#633806','#A32D2D','#0C447C'],
                borderWidth: 1.5, borderRadius: 6 }]
        },
        options: { responsive: true, plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
    });
</script>
}